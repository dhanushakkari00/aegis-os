# Frontend
NEXT_PUBLIC_APP_NAME=Aegis OS

# Backend
APP_ENV=development
APP_NAME=Aegis OS
API_V1_PREFIX=/api/v1
DEBUG=true
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:3000
SECRET_KEY=change-me-in-production

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aegis_os
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
NEXT_PUBLIC_API_BASE_URL=
INTERNAL_API_ORIGIN=http://127.0.0.1:8000

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_MODEL=gemini-2.5-flash
GOOGLE_GENAI_API_KEY=your-backend-only-gemini-key
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=your-backend-only-google-maps-key
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_FROM_EMAIL=alerts@example.com
GMAIL_FROM_NAME=Aegis OS
GMAIL_SEND_CASE_NOTIFICATIONS=true
GCS_BUCKET_NAME=aegis-os-artifacts
GCS_SIGNED_URL_TTL_SECONDS=900

MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/plain,audio/mpeg,audio/wav,audio/x-wav,audio/mp4,audio/webm,audio/ogg

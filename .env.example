# Frontend
NEXT_PUBLIC_APP_NAME=Aegis OS

# Backend
APP_ENV=development
APP_NAME=Aegis OS
API_V1_PREFIX=/api/v1
DEBUG=true
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:3000
SECRET_KEY=change-me-in-production

DATABASE_URL=sqlite:///./aegis_os.db
NEXT_PUBLIC_API_BASE_URL=
INTERNAL_API_ORIGIN=http://127.0.0.1:8000

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_MODEL=gemini-2.5-flash
GOOGLE_GENAI_API_KEY=your-backend-only-gemini-key
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=your-backend-only-google-maps-key
GCS_BUCKET_NAME=aegis-os-artifacts
GCS_SIGNED_URL_TTL_SECONDS=900

MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/plain,audio/mpeg,audio/wav,audio/x-wav,audio/mp4,audio/webm,audio/ogg

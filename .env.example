# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Aegis OS
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false

# Backend
APP_ENV=development
APP_NAME=Aegis OS
API_V1_PREFIX=/api/v1
DEBUG=true
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:3000

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aegis_os

# Optional Cloud SQL connector configuration
CLOUD_SQL_CONNECTION_NAME=
CLOUD_SQL_USE_CONNECTOR=false

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_MODEL=gemini-2.5-flash
GOOGLE_GENAI_API_KEY=your-backend-only-gemini-key
GEMINI_API_KEY=
GCS_BUCKET_NAME=aegis-os-artifacts
GCS_SIGNED_URL_TTL_SECONDS=900
CLOUD_SQL_USE_CONNECTOR=false
ALLOW_DEMO_FALLBACK=false

MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/plain
